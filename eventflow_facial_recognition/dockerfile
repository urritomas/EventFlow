# eventflow_facial_recognition/Dockerfile
# Uses Python 3.11 slim image which already has the system libs OpenCV needs.

FROM python:3.11-slim

# Install system dependencies needed by OpenCV and InsightFace
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy requirements first (better Docker layer caching)
COPY requirements.txt .

# Install Python dependencies
RUN pip install --upgrade pip && pip install -r requirements.txt

# Pre-download the InsightFace buffalo_l model during build
# so the first request isn't slow
RUN python -c "\
from insightface.app import FaceAnalysis; \
app = FaceAnalysis(name='buffalo_l', providers=['CPUExecutionProvider']); \
app.prepare(ctx_id=-1, det_size=(640, 640)); \
print('Model ready.')"

# Copy the rest of the application
COPY . .

# Expose port (Render sets $PORT dynamically)
EXPOSE 8000

# Start the API server
CMD uvicorn api:app --host 0.0.0.0 --port ${PORT:-8000}